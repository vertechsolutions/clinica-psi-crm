# ── IA (Google Gemini) ─────────────────────────────────────────────
# A assistente usa a API do Google Gemini. Key grátis no Google AI Studio:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional — modelo (default gemini-2.5-flash, do free tier).
# GEMINI_MODEL=gemini-2.5-flash

# ── Banco (Postgres do Railway) ────────────────────────────────────
# No Railway, provisione o plugin Postgres e referencie:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Em produção use a URL interna (*.railway.internal): sem SSL, sem egress.
# Sem DATABASE_URL o app sobe, mas o webhook do WhatsApp fica inativo.
DATABASE_URL=

# ── WhatsApp Cloud API (Meta) ──────────────────────────────────────
# Token permanente (System User) do app da Meta. NUNCA commitar.
WHATSAPP_TOKEN=
# Phone Number ID do número da clínica (WhatsApp Manager).
WHATSAPP_PHONE_NUMBER_ID=1121282344409820
# Token que VOCÊ inventa e cola no campo "Verify token" do webhook no App Dashboard.
WHATSAPP_VERIFY_TOKEN=
# App Secret do app Meta (App Dashboard > Settings > Basic). Valida a assinatura do webhook.
WHATSAPP_APP_SECRET=
# Opcional — versão da Graph API (default v25.0).
# WHATSAPP_GRAPH_VERSION=v25.0

# ── Admin (tela de calibração + exclusão de dados) ─────────────────
# Chave pra editar o raciocínio ativo (/api/config) e apagar dados de paciente
# (/api/admin/patient). Invente uma senha forte. Sem ela, em produção esses
# endpoints recusam acesso. A tela pede essa chave no campo "chave de admin".
ADMIN_API_KEY=

# ── Railway (deploy) ───────────────────────────────────────────────
# Fixa o Node do build (Next 16 exige >=20.9). Setar como env var no Railway:
# RAILPACK_NODE_VERSION=22

# ── Formulário + handoff (goals 4, 8) ──────────────────────────────
# Link do Google Forms de triagem. Sem ele, {FORM_URL} vaza como placeholder.
FORM_URL=
# Números que recebem o alerta quando o form é enviado (E.164 sem "+", vírgula).
NOTIFY_ALERT_NUMBERS=5527981178233,5549999551051
# Modelo Gemini p/ transcrição de áudio (mais barato). Cai no GEMINI_MODEL se vazio.
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash-lite

# ── Agenda no Google Sheets (goals 2, 5) ───────────────────────────
# JSON da Service Account (uma linha). Sem isto, a Camila não lê a agenda (fallback).
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID da planilha "Cazule — Agenda" (da URL /spreadsheets/d/<ID>/edit).
AGENDA_SHEET_ID=

# ── Follow-up proativo (goal 3) ────────────────────────────────────
# Liga/desliga o cron de reengajamento. "false" desativa por completo.
FOLLOWUP_ENABLED=true
# Nome do template aprovado na Meta p/ reengajar fora da janela de 24h.
FOLLOWUP_TEMPLATE_NAME=
