# Copie este arquivo para .env.local e preencha com a key Anthropic da Vertech.
# A aba "Teste" (assistente) usa essa key pra conversar via Claude API.
ANTHROPIC_API_KEY=

# Opcional — troca o modelo. Default: claude-opus-4-8 (mais esperto).
# Pra baratear em volume: claude-haiku-4-5  ou  claude-sonnet-4-6
# ASSISTANT_MODEL=claude-haiku-4-5
