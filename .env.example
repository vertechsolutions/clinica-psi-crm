# -- IA (Google Gemini) -------------------------------------------------
# A assistente usa a API do Google Gemini. Key gratis no Google AI Studio:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional - modelo (default gemini-2.5-flash, do free tier).
# GEMINI_MODEL=gemini-2.5-flash

# -- Banco (Postgres do Railway) ---------------------------------------
# No Railway, provisione o plugin Postgres e referencie:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Em producao use a URL interna (*.railway.internal): sem SSL, sem egress.
# Sem DATABASE_URL o app sobe, mas o webhook do WhatsApp fica inativo.
DATABASE_URL=

# -- WhatsApp Cloud API (Meta) -----------------------------------------
# Token permanente (System User) do app da Meta. NUNCA commitar.
WHATSAPP_TOKEN=
# Phone Number ID do numero da clinica (WhatsApp Manager).
WHATSAPP_PHONE_NUMBER_ID=1121282344409820
# Token que VOCE inventa e cola no campo "Verify token" do webhook no App Dashboard.
WHATSAPP_VERIFY_TOKEN=
# App Secret do app Meta (App Dashboard > Settings > Basic). Valida a assinatura do webhook.
WHATSAPP_APP_SECRET=
# Opcional - versao da Graph API (default v25.0).
# WHATSAPP_GRAPH_VERSION=v25.0

# -- Admin (tela de calibracao + exclusao de dados) --------------------
# Chave pra editar o raciocinio ativo (/api/config) e apagar dados de paciente
# (/api/admin/patient). Invente uma senha forte. Sem ela, em producao esses
# endpoints recusam acesso. A tela pede essa chave no campo "chave de admin".
ADMIN_API_KEY=

# -- Railway (deploy) ---------------------------------------------------
# Fixa o Node do build (Next 16 exige >=20.9). Setar como env var no Railway:
# RAILPACK_NODE_VERSION=22
