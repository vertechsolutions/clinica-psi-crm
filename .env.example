# A aba "Teste" (assistente) usa a API do Google Gemini.
# Pegue uma key grátis no Google AI Studio: https://aistudio.google.com/apikey
# Copie este arquivo para .env.local e preencha:
GEMINI_API_KEY=

# Opcional — modelo (default gemini-2.5-flash, do free tier).
# Alternativas: gemini-2.0-flash, gemini-flash-latest
# GEMINI_MODEL=gemini-2.5-flash
